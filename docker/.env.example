# Meta API Hub - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# Admin authentication token (required, change this!)
AUTH_TOKEN=change-me-admin-token

# Proxy API token used for OpenAI-compatible proxy endpoint (required, change this!)
PROXY_TOKEN=change-me-proxy-sk-token
# Optional high stream hardening limits. Defaults are intentionally high for long reasoning/tool outputs.
# PROXY_STREAM_MAX_SSE_BUFFER_BYTES=16777216
# PROXY_STREAM_MAX_REASONING_BYTES=134217728
# PROXY_STREAM_MAX_CONTENT_BYTES=134217728
# PROXY_STREAM_MAX_TOOL_ARGUMENT_BYTES=134217728
# PROXY_STREAM_MAX_AGGREGATE_BYTES=268435456
PORT=4000
NOTIFY_COOLDOWN_SEC=300
ADMIN_IP_ALLOWLIST=
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Auto check-in cron (default: 8:00 AM every day)
CHECKIN_CRON=0 8 * * *

# Balance refresh cron (default: every hour)
BALANCE_REFRESH_CRON=0 * * * *
